<!DOCTYPE html>
<html>
<head>
<title>Admin Login</title>
<style>
body{
font-family:Segoe UI;
background:linear-gradient(to right,#eef2f7,#f9fbfd);
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}
.login-box{
background:white;
padding:40px;
border-radius:12px;
box-shadow:0 6px 20px rgba(0,0,0,0.1);
width:300px;
text-align:center;
}
input{
width:100%;
padding:8px;
margin:10px 0;
border-radius:6px;
border:1px solid #ddd;
}
button{
width:100%;
padding:8px;
border:none;
background:#2c3e50;
color:white;
border-radius:6px;
cursor:pointer;
}
button:hover{
background:#34495e;
}
.error{
color:red;
font-size:13px;
margin-bottom:10px;
}
</style>
</head>
<body>

<div class="login-box">
<h2>Admin Login</h2>

<% if (typeof error !== 'undefined' && error) { %>
<div class="error"><%= error %></div>
<% } %>

<form method="POST" action="/login">
<input type="text" name="username" placeholder="Username" required>
<input type="password" name="password" placeholder="Password" required>
<button type="submit">Login</button>
</form>

</div>

</body>
</html>